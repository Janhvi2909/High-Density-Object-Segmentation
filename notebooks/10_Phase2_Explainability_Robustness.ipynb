    "---\n",
    "## 1. Grad-CAM: Gradient-Weighted Class Activation Mapping\n",
    "\n",
    "Grad-CAM (Selvaraju et al., ICCV 2017) generates visual explanations by computing the\n",
    "gradient of the class score with respect to the final convolutional feature map:\n",
    "\n",
    "$$\\alpha_k^c = \\underbrace{\\frac{1}{Z}\\sum_i\\sum_j}_{\\text{global avg}} \\frac{\\partial y^c}{\\partial A^k_{ij}}$$\n",
    "\n",
    "$$\\text{Grad-CAM}^c = \\text{ReLU}\\left(\\sum_k \\alpha_k^c A^k\\right)$$\n",
    "\n",
    "where $A^k$ is the $k$-th feature map, $y^c$ is the class score, and $Z = H \\times W$ normalises.\n",
    "The ReLU keeps only positive influences (features that increase the class score).\n",
    "\n",
    "**Why Grad-CAM validates our model:**\n",
    "- Confirms the model attends to product boundaries and not background noise\n",
    "- Shows whether DCAM causes the model to focus differently in dense vs. sparse regions\n",
    "- Identifies pathological cases where the model attends to wrong features"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-3",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─────────────────────────────────────────────────────────────────\n",
    "# Grad-CAM Implementation from Scratch\n",
    "# ─────────────────────────────────────────────────────────────────\n",
    "\n",
    "class GradCAM:\n",
    "    \"\"\"\n",
    "    Gradient-weighted Class Activation Maps.\n",
    "    Works by hooking into the target convolutional layer to capture:\n",
    "      1. Forward activations (feature maps)\n",
    "      2. Backward gradients (gradient of class score wrt feature maps)\n",
    "    \"\"\"\n",
    "\n",
    "    def __init__(self, model: nn.Module, target_layer: nn.Module):\n",
    "        self.model = model\n",
    "        self.target_layer = target_layer\n",
    "        self.activations = None\n",
    "        self.gradients   = None\n",
    "        self._register_hooks()\n",
    "\n",
    "    def _register_hooks(self):\n",
    "        def forward_hook(module, input, output):\n",
    "            self.activations = output.detach()\n",
    "\n",
    "        def backward_hook(module, grad_input, grad_output):\n",
    "            self.gradients = grad_output[0].detach()\n",
    "\n",
    "        self.target_layer.register_forward_hook(forward_hook)\n",
    "        self.target_layer.register_backward_hook(backward_hook)\n",
    "\n",
    "    def generate(self, input_tensor: torch.Tensor, class_idx: int = None) -> np.ndarray:\n",
    "        \"\"\"\n",
    "        Generate Grad-CAM heatmap for the given input.\n",
    "\n",
    "        Args:\n",
    "            input_tensor: (1, C, H, W) input image tensor\n",
    "            class_idx: target class index (None = argmax)\n",
    "\n",
    "        Returns:\n",
    "            cam: normalised heatmap (H, W) in [0, 1]\n",
    "        \"\"\"\n",
    "        self.model.eval()\n",
    "        input_tensor.requires_grad_(True)\n",
    "\n",
    "        # Forward pass\n",
    "        logits = self.model(input_tensor)\n",
    "\n",
    "        if class_idx is None:\n",
    "            class_idx = logits.argmax(dim=1).item()\n",
    "\n",
    "        # Zero gradients and backward\n",
    "        self.model.zero_grad()\n",
    "        logits[:, class_idx].backward()\n",
    "\n",
    "        # Compute importance weights: global average pooling of gradients\n",
    "        # α_k = (1/Z) Σᵢⱼ ∂y^c/∂A^k_ij\n",
    "        weights = self.gradients.mean(dim=[2, 3], keepdim=True)  # (1, C, 1, 1)\n",
    "\n",
    "        # Weighted combination of activation maps\n",
    "        cam = (weights * self.activations).sum(dim=1, keepdim=True)  # (1, 1, H, W)\n",
    "        cam = F.relu(cam)  # Keep only positive activations\n",
    "\n",
    "        # Normalise to [0, 1]\n",
    "        cam = cam.squeeze().numpy()\n",
    "        cam = (cam - cam.min()) / (cam.max() - cam.min() + 1e-8)\n",
    "\n",
    "        return cam\n",
    "\n",
    "\n",
    "# Minimal CNN for demonstrating Grad-CAM\n",
    "class MiniDetectorCNN(nn.Module):\n",
    "    \"\"\"Simplified CNN mimicking Mask R-CNN backbone feature extraction.\"\"\"\n",
    "    def __init__(self, num_classes=2):\n",
    "        super().__init__()\n",
    "        self.features = nn.Sequential(\n",
    "            nn.Conv2d(3, 32, 3, padding=1), nn.BatchNorm2d(32), nn.ReLU(),\n",
    "            nn.Conv2d(32, 64, 3, padding=1), nn.BatchNorm2d(64), nn.ReLU(),\n",
    "            nn.MaxPool2d(2),\n",
    "            nn.Conv2d(64, 128, 3, padding=1), nn.BatchNorm2d(128), nn.ReLU(),\n",
    "            nn.Conv2d(128, 256, 3, padding=1), nn.BatchNorm2d(256), nn.ReLU(),  # target layer\n",
    "        )\n",
    "        self.target_conv = nn.Conv2d(256, 256, 3, padding=1)  # This is our Grad-CAM target\n",
    "        self.pool = nn.AdaptiveAvgPool2d(1)\n",
    "        self.classifier = nn.Linear(256, num_classes)\n",
    "\n",
    "    def forward(self, x):\n",
    "        x = self.features(x)\n",
    "        x = F.relu(self.target_conv(x))\n",
    "        x = self.pool(x).flatten(1)\n",
    "        return self.classifier(x)\n",
    "\n",
    "\n",
    "model  = MiniDetectorCNN(num_classes=2)\n",
    "gradcam = GradCAM(model, model.target_conv)\n",
    "\n",
    "dummy_input = torch.randn(1, 3, 64, 64)\n",
    "cam = gradcam.generate(dummy_input, class_idx=1)\n",
    "print(f'Grad-CAM output shape: {cam.shape}')\n",
    "print(f'Grad-CAM value range: [{cam.min():.3f}, {cam.max():.3f}]')\n",
    "print('Grad-CAM implementation verified successfully.')"
   ]
  },
