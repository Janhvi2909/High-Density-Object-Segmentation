    "# ─── Grad-CAM Visualisation on Simulated Shelf Images ───\n",
    "\n",
    "def create_synthetic_shelf_image(n_products=15, dense=True, seed=42):\n",
    "    \"\"\"Generate a synthetic shelf image with rectangular products.\"\"\"\n",
    "    rng = np.random.default_rng(seed)\n",
    "    img = np.ones((224, 224, 3)) * 0.9  # shelf background\n",
    "    # Shelf lines\n",
    "    for y in [60, 120, 180]:\n",
    "        img[y:y+3, :] = [0.6, 0.5, 0.4]\n",
    "\n",
    "    products = []\n",
    "    for i in range(n_products):\n",
    "        if dense:\n",
    "            x = 5 + (i % 7) * 30 + rng.integers(-3, 4)\n",
    "            y = 15 + (i // 7) * 60 + rng.integers(-5, 6)\n",
    "        else:\n",
    "            x = rng.integers(10, 190)\n",
    "            y = rng.integers(10, 190)\n",
    "        w, h = rng.integers(20, 35), rng.integers(30, 55)\n",
    "        color = rng.random(3) * 0.8\n",
    "        x2, y2 = min(x+w, 223), min(y+h, 223)\n",
    "        img[y:y2, x:x2] = color\n",
    "        # Product label strip\n",
    "        img[y:y+5, x:x2] = color * 0.6\n",
    "        products.append((x, y, x2, y2))\n",
    "    return img, products\n",
    "\n",
    "\n",
    "fig, axes = plt.subplots(2, 4, figsize=(16, 8))\n",
    "\n",
    "scenarios = [\n",
    "    ('Dense shelf\\n(15 products)', True, 15, 42),\n",
    "    ('Sparse shelf\\n(5 products)',  False, 5, 123),\n",
    "]\n",
    "\n",
    "for row, (title, dense, n_prod, seed) in enumerate(scenarios):\n",
    "    img, products = create_synthetic_shelf_image(n_products=n_prod, dense=dense, seed=seed)\n",
    "    img_tensor = torch.tensor(img.transpose(2, 0, 1), dtype=torch.float32).unsqueeze(0)\n",
    "\n",
    "    # Generate Grad-CAM\n",
    "    model_fresh = MiniDetectorCNN()\n",
    "    gc = GradCAM(model_fresh, model_fresh.target_conv)\n",
    "    cam = gc.generate(img_tensor, class_idx=1)\n",
    "    cam_resized = np.array([\n",
    "        [cam[int(i/224*cam.shape[0]), int(j/224*cam.shape[1])]\n",
    "         for j in range(224)]\n",
    "        for i in range(224)\n",
    "    ])\n",
    "\n",
    "    # Original image\n",
    "    axes[row, 0].imshow(img)\n",
    "    axes[row, 0].set_title(f'{title}\\nOriginal Image', fontweight='bold')\n",
    "    axes[row, 0].axis('off')\n",
    "\n",
    "    # Grad-CAM heatmap\n",
    "    im = axes[row, 1].imshow(cam_resized, cmap='jet', vmin=0, vmax=1)\n",
    "    axes[row, 1].set_title('Grad-CAM Heatmap\\n(class: product)', fontweight='bold')\n",
    "    axes[row, 1].axis('off')\n",
    "    plt.colorbar(im, ax=axes[row, 1], fraction=0.046)\n",
    "\n",
    "    # Overlay\n",
    "    axes[row, 2].imshow(img)\n",
    "    axes[row, 2].imshow(cam_resized, cmap='jet', alpha=0.5, vmin=0, vmax=1)\n",
    "    axes[row, 2].set_title('Grad-CAM Overlay\\n(red = high attention)', fontweight='bold')\n",
    "    axes[row, 2].axis('off')\n",
    "\n",
    "    # GT bounding boxes\n",
    "    axes[row, 3].imshow(img)\n",
    "    for (x1, y1, x2, y2) in products:\n",
    "        rect = plt.Rectangle((x1, y1), x2-x1, y2-y1,\n",
    "                               fill=False, edgecolor='lime', linewidth=1.5)\n",
    "        axes[row, 3].add_patch(rect)\n",
    "    axes[row, 3].set_title('GT Bounding Boxes\\n(for reference)', fontweight='bold')\n",
