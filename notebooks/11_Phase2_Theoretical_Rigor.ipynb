    "# ─── Gradient Flow Analysis: With vs Without Skip Connections ───\n",
    "\n",
    "def simulate_gradient_flow(n_layers: int, weight_scale: float,\n",
    "                            has_skip: bool, n_trials: int = 100) -> np.ndarray:\n",
    "    \"\"\"\n",
    "    Simulate gradient magnitudes through a deep network.\n",
    "    Weights ~ N(0, weight_scale²), activations: ReLU.\n",
    "    Returns: array of gradient norms at each layer (averaged over trials).\n",
    "    \"\"\"\n",
    "    all_grads = np.zeros(n_layers)\n",
    "    for _ in range(n_trials):\n",
    "        h = np.random.randn(64)\n",
    "        activations = [h.copy()]\n",
    "        weights     = [np.random.randn(64, 64) * weight_scale for _ in range(n_layers)]\n",
    "\n",
    "        # Forward pass\n",
    "        for w in weights:\n",
    "            h_new = np.maximum(0, w @ h)  # ReLU\n",
    "            if has_skip:\n",
    "                h_new = h_new + h  # residual addition\n",
    "            h = h_new\n",
    "            activations.append(h.copy())\n",
    "\n",
    "        # Backward pass (gradient of L2 loss)\n",
    "        grad = h / (np.linalg.norm(h) + 1e-8)\n",
    "        layer_grads = [np.linalg.norm(grad)]\n",
    "\n",
    "        for l in range(n_layers - 1, -1, -1):\n",
    "            w = weights[l]\n",
    "            a = activations[l + 1]\n",
    "            # ReLU mask\n",
    "            relu_mask = (a > 0).astype(float)\n",
    "            if has_skip:\n",
    "                grad = w.T @ (grad * relu_mask) + grad  # skip\n",
    "            else:\n",
    "                grad = w.T @ (grad * relu_mask)\n",
    "            layer_grads.append(np.linalg.norm(grad))\n",
    "\n",
    "        all_grads += np.array(layer_grads[::-1][:n_layers])\n",
    "\n",
    "    return all_grads / n_trials\n",
    "\n",
    "\n",
    "n_layers = 20\n",
    "\n",
    "grads_no_skip   = simulate_gradient_flow(n_layers, 0.12, has_skip=False)\n",
    "grads_with_skip = simulate_gradient_flow(n_layers, 0.12, has_skip=True)\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(12, 5))\n",
    "\n",
    "layer_idx = np.arange(1, n_layers + 1)\n",
    "\n",
    "axes[0].semilogy(layer_idx, grads_no_skip,   'r-o', lw=2, ms=5, label='No skip connections')\n",
    "axes[0].semilogy(layer_idx, grads_with_skip, 'g-s', lw=2, ms=5, label='With residual (skip) connections')\n",
    "axes[0].set_xlabel('Layer index (from input)', fontsize=11)\n",
    "axes[0].set_ylabel('Gradient norm (log scale)', fontsize=11)\n",
    "axes[0].set_title(f'Gradient Flow in {n_layers}-layer Network\\n(Log scale — skip prevents vanishing)', fontweight='bold')\n",
