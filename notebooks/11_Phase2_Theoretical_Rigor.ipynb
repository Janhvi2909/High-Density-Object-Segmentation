    "iou_vals = []; giou_vals = []; l1_vals = []\n",
    "for s in shifts:\n",
    "    pred = gt_box + np.array([s, 0, s, 0])  # horizontal shift\n",
    "    pred = np.clip(pred, 0, 1)\n",
    "    iou_vals.append(compute_iou(gt_box, pred))\n",
    "    giou_vals.append(compute_giou(gt_box, pred))\n",
    "    l1_vals.append(np.abs(gt_box - pred).mean())\n",
    "\n",
    "axes[1, 0].plot(shifts, iou_vals,  'b-', lw=2, label='IoU')\n",
