    "for gamma, color in zip(gammas, colors):\n",
    "    # |∂FL/∂p| = (1-p)^γ * (1/p) * ... simplified\n",
    "    grad = (1-p_range)**gamma * (1/p_range) - gamma * (1-p_range)**(gamma-1) * np.log(p_range+1e-7)\n",
