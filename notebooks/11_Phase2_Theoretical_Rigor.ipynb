    "w1 = np.linspace(-2, 2, 40)\n",
    "w2 = np.linspace(-2, 2, 40)\n",
    "W1, W2 = np.meshgrid(w1, w2)\n",
    "\n",
    "# Simplified 2D loss landscape (bowl with flat regions)\n",
    "Z_convex  = 0.5 * W1**2 + 0.5 * W2**2 + 0.3 * np.sin(2*W1) * np.cos(2*W2)\n",
    "Z_complex = 0.3 * W1**2 + 0.3 * W2**2 + 1.5 * np.sin(W1) * np.sin(W2) + 0.2 * np.cos(3*W1)\n",
    "\n",
    "surf = ax3d.plot_surface(W1, W2, Z_complex, cmap='viridis', alpha=0.8)\n",
    "ax3d.set_xlabel('W₁')\n",
    "ax3d.set_ylabel('W₂')\n",
    "ax3d.set_zlabel('Loss')\n",
    "ax3d.set_title('Loss Landscape\\n(non-convex with local minima)', fontweight='bold', fontsize=9)\n",
    "\n",
    "# Row 2: GIoU vs IoU vs L1\n",
    "# Simulate two boxes — vary prediction width\n",
    "gt_box  = np.array([0.3, 0.3, 0.7, 0.7])  # (x1,y1,x2,y2)\n",
    "shifts  = np.linspace(-0.4, 0.4, 200)\n",
    "\n",
    "def compute_iou(b1, b2):\n",
    "    ix1 = max(b1[0], b2[0]); iy1 = max(b1[1], b2[1])\n",
    "    ix2 = min(b1[2], b2[2]); iy2 = min(b1[3], b2[3])\n",
    "    inter = max(0, ix2-ix1) * max(0, iy2-iy1)\n",
    "    area1 = (b1[2]-b1[0])*(b1[3]-b1[1])\n",
    "    area2 = (b2[2]-b2[0])*(b2[3]-b2[1])\n",
    "    union = area1 + area2 - inter + 1e-7\n",
    "    return inter / union\n",
    "\n",
    "def compute_giou(b1, b2):\n",
    "    iou   = compute_iou(b1, b2)\n",
    "    ex1   = min(b1[0], b2[0]); ey1 = min(b1[1], b2[1])\n",
    "    ex2   = max(b1[2], b2[2]); ey2 = max(b1[3], b2[3])\n",
    "    enc   = (ex2-ex1)*(ey2-ey1) + 1e-7\n",
    "    area1 = (b1[2]-b1[0])*(b1[3]-b1[1])\n",
    "    area2 = (b2[2]-b2[0])*(b2[3]-b2[1])\n",
    "    union = area1 + area2 - (compute_iou(b1, b2) * (area1+area2-compute_iou(b1,b2)*(area1+area2)))\n",
    "    return iou - (enc - (area1+area2-iou*(area1+area2))) / enc\n",
