   "source": [
    "# ─── Focal Loss Mathematics: Numerical Verification ───\n",
    "\n",
    "import torch\n",
    "\n",
    "def focal_loss_manual(p, y, gamma=2.0, alpha=0.25):\n",
    "    \"\"\"Manual focal loss computation to verify the derivation.\"\"\"\n",
    "    p_t     = p * y + (1 - p) * (1 - y)\n",
    "    alpha_t = alpha * y + (1 - alpha) * (1 - y)\n",
    "    return -alpha_t * (1 - p_t)**gamma * torch.log(p_t.clamp(1e-7))\n",
    "\n",
    "def focal_loss_gradient(p, y, gamma=2.0):\n",
    "    \"\"\"Analytical gradient of FL wrt logit z, using chain rule derivation above.\"\"\"\n",
    "    eps = 1e-7\n",
    "    # For y=1: ∂FL/∂z = (1-p)^(γ-1) * [-(1-p)^2 + γ·p·(1-p)·log(p+ε)]\n",
    "    mask_pos  = (y == 1).float()\n",
    "    mask_neg  = (y == 0).float()\n",
    "    grad_pos  = (1-p)**(gamma-1) * (-(1-p)**2 + gamma * p * (1-p) * torch.log(p + eps))\n",
    "    # For y=0: symmetric derivation\n",
    "    grad_neg  = p**(gamma-1) * (-(p)**2 + gamma * (1-p) * p * torch.log(1-p + eps))\n",
    "    return mask_pos * grad_pos + mask_neg * grad_neg\n",
    "\n",
    "\n",
    "# Verify gradient numerically\n",
    "p_test = torch.tensor([0.1, 0.5, 0.9, 0.99], requires_grad=True)\n",
    "y_test = torch.ones(4)\n",
    "gamma  = 2.0\n",
    "\n",
    "loss   = focal_loss_manual(p_test, y_test, gamma=gamma).sum()\n",
    "loss.backward()\n",
    "\n",
    "print('Focal Loss Gradient Verification (Positive class, γ=2):')\n",
    "print(f'{\"p\":>8} {\"FL(p,1)\":>12} {\"∂FL/∂p (autograd)\":>20} {\"Magnitude ratio vs BCE\"}')\n",
    "print('-'*65)\n",
    "bce_grads = -(1/p_test.detach())\n",
    "for i, (p_val, grad_fl, grad_bce) in enumerate(zip(\n",
    "        p_test.detach().numpy(),\n",
    "        p_test.grad.numpy(),\n",
    "        bce_grads.numpy())):\n",
    "    fl_val = focal_loss_manual(torch.tensor(p_val), torch.tensor(1.0), gamma=gamma).item()\n",
    "    ratio  = abs(grad_fl) / abs(grad_bce) if abs(grad_bce) > 1e-10 else float('inf')\n",
    "    print(f'{p_val:>8.3f} {fl_val:>12.5f} {grad_fl:>20.5f}   {ratio:>8.4f}× BCE')\n",
    "\n",
    "print('\\nAt p=0.99 (easy positive), Focal suppresses gradient ~{:.0f}× relative to BCE.'.format(\n",
    "    abs(bce_grads[3].item()) / abs(p_test.grad[3].item())))"
   ]
