    "axes[1, 2].hist(raw_activations,  bins=50, alpha=0.6, color='#e74c3c', label=f'Raw  μ={raw_activations.mean():.1f}, σ={raw_activations.std():.1f}', density=True)\n",
    "axes[1, 2].hist(norm_activations, bins=50, alpha=0.6, color='#3498db', label=f'BN   μ={norm_activations.mean():.2f}, σ={norm_activations.std():.2f}', density=True)\n",
    "axes[1, 2].hist(gamma_scaled,     bins=50, alpha=0.6, color='#27ae60', label=f'BN+γβ μ={gamma_scaled.mean():.2f}, σ={gamma_scaled.std():.2f}', density=True)\n",
    "axes[1, 2].set_xlabel('Activation value')\n",
    "axes[1, 2].set_ylabel('Density')\n",
    "axes[1, 2].set_title('Batch Normalisation: Distribution Shift\\n(stabilises training, prevents gradient issues)', fontweight='bold')\n",
