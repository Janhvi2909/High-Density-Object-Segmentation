    "# ─── Verify DCAM Gradient Numerically ───\n",
    "\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "\n",
    "class SimpleDCAM(nn.Module):\n",
    "    \"\"\"Minimal DCAM for gradient verification.\"\"\"\n",
    "    def __init__(self, C, mid=8):\n",
    "        super().__init__()\n",
    "        self.fc_feat = nn.Linear(C, mid)\n",
    "        self.fc_dens = nn.Linear(1, mid)\n",
    "        self.fc_out  = nn.Linear(mid * 2, C)\n",
    "\n",
    "    def forward(self, F_in, D):\n",
    "        z_f = F.adaptive_avg_pool2d(F_in, 1).flatten(1)    # (B, C)\n",
    "        z_d = F.adaptive_avg_pool2d(D, 1).flatten(1)       # (B, 1)\n",
    "        h   = torch.relu(torch.cat([self.fc_feat(z_f), self.fc_dens(z_d)], dim=1))\n",
    "        s   = torch.sigmoid(self.fc_out(h)).unsqueeze(-1).unsqueeze(-1)\n",
    "        return F_in * s\n",
    "\n",
    "\n",
    "# Test gradients using torch.autograd.gradcheck\n",
    "dcam = SimpleDCAM(C=8, mid=4).double()  # double precision for gradcheck\n",
    "\n",
    "F_test = torch.randn(2, 8, 4, 4, dtype=torch.double, requires_grad=True)\n",
    "D_test = torch.rand(2, 1, 4, 4, dtype=torch.double, requires_grad=True)\n",
    "\n",
    "from torch.autograd import gradcheck\n",
    "try:\n",
    "    result = gradcheck(dcam, (F_test, D_test), eps=1e-5, atol=1e-3, rtol=1e-3)\n",
    "    print(f'Gradient check: {\"PASSED ✓\" if result else \"FAILED ✗\"}')\n",
    "except Exception as e:\n",
    "    print(f'Gradient check result: {e}')\n",
    "\n",
    "# Also verify that gradients flow to the density map\n",
    "dcam_float = SimpleDCAM(C=8, mid=4)\n",
    "F_float = torch.randn(2, 8, 4, 4, requires_grad=True)\n",
    "D_float = torch.rand(2, 1, 4, 4, requires_grad=True)\n",
    "\n",
    "output = dcam_float(F_float, D_float)\n",
    "loss   = output.sum()\n",
    "loss.backward()\n",
    "\n",
    "print(f'\\nGradient wrt F:    norm = {F_float.grad.norm().item():.4f}  (non-zero = correct)')\n",
    "print(f'Gradient wrt D:    norm = {D_float.grad.norm().item():.4f}  (non-zero = density is differentiable)')\n",
    "print(f'Gradient wrt W1:   norm = {dcam_float.fc_feat.weight.grad.norm().item():.4f}')\n",
    "print(f'Gradient wrt W2:   norm = {dcam_float.fc_dens.weight.grad.norm().item():.4f}')\n",
    "print('\\nConclusion: DCAM is fully differentiable — density map gradients allow')\n",
    "print('end-to-end training of a learnable density estimator upstream.')"
   ]
